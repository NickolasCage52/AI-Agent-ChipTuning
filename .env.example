# Gemini (обязательно для LLM)
GEMINI_API_KEY=your_gemini_api_key
# Модель: gemini-1.5-flash (стабильно) или gemini-2.0-flash
GEMINI_MODEL=gemini-1.5-flash

# Telegram Bot (Parts Assistant — поиск по прайсам)
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# SQLite БД (прайсы)
DB_PATH=data/parts.db
PRICE_BASE_PATH=data/price_sources/base.xlsx
PRICE_DEFECT_PATH=data/price_sources/defect.xlsx

# PostgreSQL (для core-api, agent-orchestrator, rag)
DATABASE_URL=postgresql://autoshop:autoshop@postgres:5432/autoshop
ASYNC_DATABASE_URL=postgresql+asyncpg://autoshop:autoshop@postgres:5432/autoshop

# Логирование
LOG_LEVEL=INFO

# UI порт (если 3000 занят — укажите 3001)
UI_PORT=3001

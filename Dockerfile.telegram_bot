# Parts Assistant Telegram Bot — поиск только по прайсам (SQLite)
FROM python:3.12-slim

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app

COPY requirements-telegram-bot.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt

COPY core/ /app/core/
COPY llm/ /app/llm/
COPY storage/ /app/storage/
COPY config/ /app/config/
COPY apps/ /app/apps/
COPY scripts/ /app/scripts/
COPY data/ /app/data/

CMD ["python", "-m", "apps.telegram_bot.bot"]
